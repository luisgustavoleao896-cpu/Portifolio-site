<!DOCTYPE html>
<html>
<head>
<title>Dashboard</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

<h2>Vendas</h2>
<canvas id="grafico"></canvas>

<script>
new Chart(document.getElementById("grafico"), {
  type: 'bar',
  data: {
    labels: ["Jan","Fev","Mar"],
    datasets: [{
      label: "Vendas",
      data: [10,20,30]
    }]
  }
});
</script>

</body>
</html>
